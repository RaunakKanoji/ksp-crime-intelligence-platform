{
  "table": "incident_locations",
  "purpose": "Detailed location records for incidents.",
  "creationOrder": 12,
  "tableScope": "operational",
  "columns": [
    { "name": "location_id", "type": "Var Char", "maxLength": 120, "mandatory": true, "unique": true },
    { "name": "incident_id", "type": "Var Char", "maxLength": 120, "mandatory": true, "foreignKey": "crime_incidents.incident_id" },
    { "name": "latitude", "type": "Decimal", "mandatory": true },
    { "name": "longitude", "type": "Decimal", "mandatory": true },
    { "name": "address_text", "type": "Text", "mandatory": false },
    { "name": "created_at", "type": "Date Time", "mandatory": true },
    { "name": "created_by", "type": "Var Char", "maxLength": 100, "mandatory": true },
    { "name": "updated_at", "type": "Date Time", "mandatory": true },
    { "name": "updated_by", "type": "Var Char", "maxLength": 100, "mandatory": true },
    { "name": "version", "type": "Integer", "mandatory": true, "default": 1 },
    { "name": "is_deleted", "type": "Boolean", "mandatory": true, "default": false }
  ],
  "relationships": ["crime_incidents.incident_id"],
  "searchableFields": ["location_id", "incident_id"],
  "indexRecommendations": ["location_id", "incident_id", "is_deleted"],
  "rolePermissions": { "read": ["Jurisdiction scoped"], "write": ["Admin", "Investigator", "Officer"] },
  "archiveBehavior": "Soft delete with parent incident.",
  "auditRequirements": "Audit create and update."
}
