{
  "table": "police_stations",
  "purpose": "Police station reference data linked to districts.",
  "creationOrder": 8,
  "tableScope": "reference",
  "columns": [
    { "name": "station_id", "type": "Var Char", "maxLength": 100, "mandatory": true, "unique": true },
    { "name": "district_id", "type": "Var Char", "maxLength": 100, "mandatory": true, "foreignKey": "districts.district_id" },
    { "name": "name", "type": "Var Char", "maxLength": 160, "mandatory": true },
    { "name": "status", "type": "Var Char", "maxLength": 30, "mandatory": true, "default": "active" },
    { "name": "created_at", "type": "Date Time", "mandatory": true },
    { "name": "created_by", "type": "Var Char", "maxLength": 100, "mandatory": true },
    { "name": "updated_at", "type": "Date Time", "mandatory": true },
    { "name": "updated_by", "type": "Var Char", "maxLength": 100, "mandatory": true },
    { "name": "version", "type": "Integer", "mandatory": true, "default": 1 },
    { "name": "is_deleted", "type": "Boolean", "mandatory": true, "default": false },
    { "name": "deleted_at", "type": "Date Time", "mandatory": false },
    { "name": "deleted_by", "type": "Var Char", "maxLength": 100, "mandatory": false }
  ],
  "relationships": ["districts.district_id"],
  "searchableFields": ["station_id", "district_id", "name", "status"],
  "indexRecommendations": ["station_id", "district_id", "status", "is_deleted"],
  "rolePermissions": { "read": ["Admin", "Investigator", "Analyst", "Officer", "Viewer"], "write": ["Admin"] },
  "archiveBehavior": "Soft delete only after dependent records are migrated.",
  "auditRequirements": "Audit create, update, and soft delete."
}
