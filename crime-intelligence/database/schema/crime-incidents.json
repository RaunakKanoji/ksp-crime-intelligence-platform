{
  "table": "crime_incidents",
  "purpose": "Primary operational incident records.",
  "creationOrder": 11,
  "tableScope": "operational",
  "columns": [
    { "name": "incident_id", "type": "Var Char", "maxLength": 120, "mandatory": true, "unique": true },
    { "name": "fir_number", "type": "Var Char", "maxLength": 80, "mandatory": true, "unique": true },
    { "name": "title", "type": "Var Char", "maxLength": 180, "mandatory": true },
    { "name": "description", "type": "Text", "mandatory": false },
    { "name": "crime_category_id", "type": "Var Char", "maxLength": 100, "mandatory": true, "foreignKey": "crime_categories.category_id" },
    { "name": "district_id", "type": "Var Char", "maxLength": 100, "mandatory": true, "foreignKey": "districts.district_id" },
    { "name": "station_id", "type": "Var Char", "maxLength": 100, "mandatory": true, "foreignKey": "police_stations.station_id" },
    { "name": "occurred_at", "type": "Date Time", "mandatory": true },
    { "name": "reported_at", "type": "Date Time", "mandatory": false },
    { "name": "status", "type": "Var Char", "maxLength": 40, "mandatory": true },
    { "name": "severity", "type": "Var Char", "maxLength": 30, "mandatory": true },
    { "name": "priority", "type": "Var Char", "maxLength": 30, "mandatory": true },
    { "name": "latitude", "type": "Decimal", "mandatory": false },
    { "name": "longitude", "type": "Decimal", "mandatory": false },
    { "name": "assigned_officer_id", "type": "Var Char", "maxLength": 100, "mandatory": false, "foreignKey": "officers.officer_id" },
    { "name": "created_at", "type": "Date Time", "mandatory": true },
    { "name": "created_by", "type": "Var Char", "maxLength": 100, "mandatory": true },
    { "name": "updated_at", "type": "Date Time", "mandatory": true },
    { "name": "updated_by", "type": "Var Char", "maxLength": 100, "mandatory": true },
    { "name": "version", "type": "Integer", "mandatory": true, "default": 1 },
    { "name": "is_deleted", "type": "Boolean", "mandatory": true, "default": false },
    { "name": "deleted_at", "type": "Date Time", "mandatory": false },
    { "name": "deleted_by", "type": "Var Char", "maxLength": 100, "mandatory": false }
  ],
  "relationships": ["districts.district_id", "police_stations.station_id", "crime_categories.category_id", "officers.officer_id"],
  "searchableFields": ["incident_id", "fir_number", "title", "district_id", "station_id", "status", "severity"],
  "indexRecommendations": ["incident_id", "fir_number", "district_id", "station_id", "occurred_at", "status", "is_deleted"],
  "rolePermissions": { "read": ["Jurisdiction scoped"], "write": ["Admin", "Investigator", "Officer"] },
  "archiveBehavior": "Soft delete only. Do not hard-delete operational incident records.",
  "auditRequirements": "Audit create, update, assignment, closure, and soft delete."
}
