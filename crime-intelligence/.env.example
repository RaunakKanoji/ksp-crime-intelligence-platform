NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-side application data provider. The mock provider is deterministic and
# is the default when DATA_PROVIDER is omitted. Neon wiring is documented but
# intentionally remains an explicit opt-in until the production adapter is ready.
DATA_PROVIDER=mock
MOCK_DATABASE_ENABLED=true
MOCK_DATABASE_SEED=20260720
MOCK_REFERENCE_DATE=2026-07-20
MOCK_DATABASE_LATENCY_MS=0
MOCK_DATABASE_FAILURE=false

DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require
DATABASE_URL_UNPOOLED=

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/signin
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/app
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/app

AI_PROVIDER=gemini
AI_API_KEY=
AI_MODEL=gemini-3.5-flash
GEMINI_API_KEY=
GEMINI_NLP_MODEL=gemini-3.5-flash

EMBEDDING_PROVIDER=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=

OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_REGION=
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=

NEXT_PUBLIC_MAP_STYLE_URL=
NEXT_PUBLIC_DEFAULT_MAP_LAT=12.9716
NEXT_PUBLIC_DEFAULT_MAP_LNG=77.5946
NEXT_PUBLIC_DEFAULT_MAP_ZOOM=10

# Legacy Catalyst variable retained only while Catalyst migration is in progress.
NEXT_PUBLIC_CATALYST_DOMAIN=https://ksp-crime-app-60076540751.development.catalystserverless.in
