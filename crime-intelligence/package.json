{
  "name": "nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p ${PORT:-3000}",
    "start:appsail": "node scripts/ensure-next-build.mjs && npm run start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "a11y:static": "node scripts/accessibility-static-check.mjs",
    "release:gate": "node scripts/release-gate.mjs",
    "db:validate:files": "node database/scripts/validate-database-files.mjs",
    "db:validate": "node scripts/validate-catalyst-schema.mjs",
    "db:seed": "node scripts/seed-catalyst.mjs",
    "db:seed:development": "node scripts/seed-catalyst.mjs --environment development",
    "db:import": "node scripts/import-catalyst-dataset.mjs",
    "db:schema": "node database/scripts/print-console-schema.mjs",
    "db:commands": "node database/scripts/print-import-commands.mjs",
    "db:check-env": "node database/scripts/verify-database-environment.mjs",
    "db:generate:postgres": "node database/scripts/generate-postgres-sql.mjs",
    "db:apply:postgres": "npm run db:generate:postgres && node database/scripts/run-postgres-sql.mjs schema",
    "db:seed:postgres": "npm run db:generate:postgres && node database/scripts/run-postgres-sql.mjs seeds",
    "db:seed:mock:postgres": "node database/scripts/seed-neon-mock.mjs",
    "mock:summary": "node scripts/mock-database-command.mjs summary",
    "mock:seed": "node scripts/mock-database-command.mjs seed",
    "mock:reset": "node scripts/mock-database-command.mjs reset",
    "mock:validate": "node scripts/mock-database-command.mjs validate",
    "mock:smoke": "node scripts/mock-database-smoke.mjs"
  },
  "dependencies": {
    "@deck.gl/core": "^9.3.6",
    "@deck.gl/layers": "^9.3.6",
    "@deck.gl/mapbox": "^9.3.6",
    "express": "^5.2.1",
    "h3-js": "^4.5.0",
    "maplibre-gl": "^5.24.0",
    "next": "14.2.5",
    "react": "^18",
    "react-dom": "^18",
    "zcatalyst-sdk-node": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "postcss": "^8",
    "tailwindcss": "^3.4.1"
  },
  "engines": {
    "node": "22.x"
  }
}
